# Никогда не добавляйте настоящий API-ключ в Git.
YANDEX_API_KEY=replace-with-a-new-api-key
YANDEX_FOLDER_ID=replace-with-folder-id

# Имена моделей. Docker Compose добавляет gpt://<folder-id>/ автоматически.
YANDEX_CHAT_MODEL_NAME=yandexgpt-5.1
YANDEX_QUERY_MODEL_NAME=yandexgpt-5-lite
YANDEX_EXTRACTION_MODEL_NAME=yandexgpt-5.1

# Необязательные настройки.
YANDEX_CHAT_TEMPERATURE=0.2
YANDEX_SPRING_BASE_URL=https://ai.api.cloud.yandex.net/v1
YANDEX_OPENAI_BASE_URL=https://ai.api.cloud.yandex.net/v1
YANDEX_EMBEDDING_BASE_URL=https://llm.api.cloud.yandex.net/foundationModels/v1/textEmbedding

# Максимальный размер загружаемого документа и multipart-запроса.
APP_DOCUMENT_MAX_FILE_SIZE=10GB
APP_DOCUMENT_MAX_REQUEST_SIZE=10GB
